{
  "name": "battery-annual-report",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "extract": "bun scripts/extract-report.ts && bun scripts/extract-layout.ts && bun scripts/clean-logo-backgrounds.ts",
    "verify": "bun scripts/verify-report.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@radix-ui/react-popover": "1.1.19",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-virtual": "3.14.6",
    "@vitejs/plugin-react": "6.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.3",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "prettier": "3.9.5"
  }
}
